# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_TIMEZONE=Europe/Kyiv
GENERIC_TIMEZONE=Europe/Kyiv

# Optional basic auth
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Security
N8N_ENCRYPTION_KEY=replace-with-your-own-long-random-string

# Webhook URL for local usage
WEBHOOK_URL=http://localhost:5678/

# Optional
NODE_ENV=production