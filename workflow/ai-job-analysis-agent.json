    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const id = $('Get row(s) in Google Sheet').item.json.ID;\nconst html = $json.data || '';\nconst rowNumber = $('Get row(s) in Google Sheet').item.json.row_number;\n\nconst cleaned = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<noscript[\\s\\S]*?<\\/noscript>/gi, ' ')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"')\n  .replace(/&#39;/g, \"'\")\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nreturn {\n  rowNumber,\n  id,\n  jobText: cleaned.slice(0, 20000),\n};"
      },
      "type": "n8n-nodes-base.code",
