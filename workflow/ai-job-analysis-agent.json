    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawText = $json.output?.[0]?.content?.[0]?.text;\n\nif (!rawText) {\n  throw new Error('OpenAI response text not found');\n}\n\nconst parsed = JSON.parse(rawText);\n\nconst sourceRow = $('Get row(s) in Google Sheet').item.json;\n\nreturn {\n  some: sourceRow,\n  id: sourceRow.ID,\n  jobUrl: sourceRow['Job URL'],\n  company: parsed.company || 'Not specified',\n  position: parsed.position || 'Not specified',\n  location: parsed.location || 'Not specified',\n  salary: parsed.salary || 'Not specified',\n  techStack: Array.isArray(parsed.techStack)\n    ? parsed.techStack.join(', ')\n    : parsed.techStack || 'Not specified',\n  requirements: parsed.requirements || 'Not specified',\n  matchPercent: parsed.matchPercent || 0,\n  recommendation: parsed.recommendation || 'Not specified',\n  pros: parsed.pros || 'Not specified',\n  cons: parsed.cons || 'Not specified',\n  coverLetter: parsed.coverLetter || 'Not specified',\n};"
      },
